<project name="halInit">

	<import file="${ant.file.halInit}/../../extension-init.xml" />

	<condition property="ej.hal.client.halClientIsEnabled">
		<equals arg1="${ej.hal.client.halMockMode}" arg2="HAL Remote Server"/>
	</condition>
	
	<target name="init/hal" extensionOf="init/execution" if="onS3" unless="${ej.hal.client.halClientIsEnabled}" >
		<echo message="HAL mock basic init" level="verbose" />
		<augment id="hil.main.classpath">
			<fileset dir="${jpf.dir}/mocks" includes="mockHAL.jar"/>
		</augment>
	</target>
	
</project>