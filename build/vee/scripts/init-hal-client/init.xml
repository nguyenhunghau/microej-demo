<project name="halInitClient">

	<import file="${ant.file.halInit}/../../extension-init.xml" />

	<condition property="ej.hal.client.halClientIsEnabled">
		<equals arg1="${ej.hal.client.halMockMode}" arg2="HAL Remote Server"/>
	</condition>
	
	<target name="init/hal/client" if="onS3" depends="init/hal/enableHalClient">
	</target>
	
	<target name="init/hal/enableHalClient" extensionOf="init/execution" if="${ej.hal.client.halClientIsEnabled}">
		<echo message="HAL mock client init" level="verbose" />
		<augment id="hil.main.properties">
			<propertyref name="ej.hal.client.host"/>
			<propertyref name="ej.hal.client.port"/>
			<propertyref name="ej.hal.client.timeout"/>
			<propertyref name="ej.hal.client.verboseEnabled"/>
		</augment>
		<augment id="hil.main.classpath">
			<fileset dir="${jpf.dir}/tools" includes="hal.mock.client.jar"/>
		</augment>
	</target>
	
</project>